# ==========================================
# ROBO Data Catalog 환경변수 설정
# ==========================================
# 이 파일을 .env로 복사하여 값을 설정하세요.
# cp .env.example .env
# ==========================================

# ------------------------------------------
# 필수 설정
# ------------------------------------------

# Neo4j 데이터베이스 연결
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password
NEO4J_DATABASE=neo4j

# LLM API 키 (description 생성용)
LLM_API_KEY=sk-your-api-key-here

# ------------------------------------------
# LLM 설정 (선택)
# ------------------------------------------
# LLM_MODEL=gpt-4.1
# EMBEDDING_MODEL=text-embedding-3-small

# ------------------------------------------
# 서버 설정 (선택)
# ------------------------------------------
# HOST=0.0.0.0
# PORT=5503
# CATALOG_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Electron에서 요청별 Neo4j 연결 헤더를 사용할 때만 명시적으로 활성화
# CATALOG_ALLOW_NEO4J_HEADER_OVERRIDE=false

# ------------------------------------------
# Data Fabric 연동 (샘플 행 조회 + FK 추론용 SQL 실행)
# ------------------------------------------
# 주의: robo-workspace 통합 실행은 data-fabric 을 8404 로 띄운다(Windows 예약 포트 회피).
# 로컬 단독 실행과 workspace 모두 이 공개 포트를 사용한다.
DATA_FABRIC_URL=http://127.0.0.1:8404

# ------------------------------------------
# 메타데이터 보강 설정 (선택)
# ------------------------------------------
# FK 관계 추론
# FK_INFERENCE_ENABLED=true
# FK_SAMPLE_SIZE=25
# FK_SIMILARITY_THRESHOLD=0.8
# FK_MATCH_RATIO_THRESHOLD=0.8
# FK_CONCURRENCY=5

# 타임아웃 (초)
# METADATA_TIMEOUT_CONNECT=5
# METADATA_TIMEOUT_REQUEST=30
